# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# ── Clerk (dashboard auth) ───────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Cron → Dashboard API auth ────────────────────────────────────────
# Shared secret for cron jobs to authenticate with dashboard API routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ── Buffer (Threads + TikTok posting) ────────────────────────────────
# OAuth token from Buffer — used for both Threads and TikTok channels.
# Get it from: buffer.com → Settings → API
BUFFER_ACCESS_TOKEN=your-buffer-token

# Buffer channel ID for Threads (found via Buffer's channel GraphQL query)
BUFFER_THREADS_CHANNEL_ID=your-threads-channel-id

# Buffer organization ID — used to look up the TikTok channel.
# Find at: buffer.com → Settings → Organization (check URL or API)
BUFFER_ORG_ID=your-buffer-org-id

# ── Apify (tweet scraping) ───────────────────────────────────────────
APIFY_API_KEY=your-apify-key
APIFY_TWITTER_HANDLE=AlexHormozi

# ── Dashboard URL (cron → dashboard API calls) ───────────────────────
# Base URL of the deployed dashboard. The TikTok cron calls dashboard API
# routes for video generation (canvas rendering + ffmpeg run server-side).
# Example: https://command-center-dashboard.onrender.com
DASHBOARD_URL=https://your-dashboard.onrender.com

# ── TikTok pipeline (optional) ───────────────────────────────────────
# Minimum like count for tweet filtering (default: 4000)
# TIKTOK_MIN_LIKES=4000
# Max tweets to fetch from Apify (default: 30)
# TIKTOK_MAX_ITEMS=30

# ── YouTube (2nd channel — direct upload) ───────────────────────────
# OAuth client for the second YouTube channel. Mint the refresh token
# once via: python scripts/generate_youtube_second_refresh_token.py
# (select the 2nd channel in Google's channel picker).
YOUTUBE_SECOND_CLIENT_ID=your-youtube-second-client-id
YOUTUBE_SECOND_CLIENT_SECRET=your-youtube-second-client-secret
YOUTUBE_SECOND_REFRESH_TOKEN=your-youtube-second-refresh-token

# Optional: override the default channel description. Must be ≤5000 chars.
# YOUTUBE_SECOND_DESCRIPTION=Uploaded via Command Center. Follow for more.

# Expected channel ID — videos that verify against a different channel
# are rejected by /api/youtube-second/upload-complete. Default:
# UCrvch01h6lWZAuGaa1LqX9Q (Hormozi Highlights).
YOUTUBE_SECOND_CHANNEL_ID=UCrvch01h6lWZAuGaa1LqX9Q

# Browser origin echoed as the `Origin` header on the init POST to
# YouTube's resumable endpoint — required so Google's CORS response on
# the upload URL allows the browser's subsequent PUTs. Used as fallback
# when the incoming request's Origin isn't in the allowlist below.
YOUTUBE_SECOND_BROWSER_ORIGIN=https://app.media-command.com

# Optional: comma-separated allowlist of incoming browser origins. The
# upload-init route forwards the incoming Origin to Google only if it
# appears here (otherwise falls back to YOUTUBE_SECOND_BROWSER_ORIGIN).
# If unset, defaults to: https://app.media-command.com,http://localhost:3000
# Add staging here without a code change.
# YOUTUBE_SECOND_ALLOWED_ORIGINS=https://app.media-command.com,http://localhost:3000,https://staging.media-command.com

# Direct Postgres connection (session pooler, port 5432) used only by
# the youtube-second upload-init route for its advisory-lock-guarded
# slot claim. Find it at Supabase → Project Settings → Database → Session
# Pooler → "URI" tab.
SUPABASE_SESSION_POOLER_URL=postgres://postgres.xyz:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
