# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
python_deps/

# Node / Next.js
node_modules/
dashboard/.next/
dashboard/out/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code local state (worktrees, etc)
.claude/worktrees/

# Generated media (transient — created by ig-pipeline, not committed)
exports/
dashboard/exports/

# Supabase local
supabase/.temp/
supabase/.branches/

# Playwright MCP server scratch dir (console logs + page snapshots auto-
# generated when Claude drives the browser; safe to ignore).
.playwright-mcp/

# Local working artifacts at the repo root — screenshots used while
# iterating on UI mocks, and one-off CSV/JSON exports from Buffer or
# YouTube Studio. Source code lives in dashboard/, cron/, core/ — root
# PNG/CSV/JSON files are always scratch. The leading `/` keeps the
# match anchored to the repo root so package.json / tsconfig.json files
# in subdirectories stay tracked.
/*.png
/*.csv
/*.json

# Per-platform tweet-bank usage history. These are runtime state — each
# cron tick records which hashes have been posted so the picker can
# exclude them next time. NOTE: `data/ig-bank-history.json` predates
# this rule and was already tracked when the convention shifted; this
# pattern only blocks NEW history files from auto-staging (`.gitignore`
# doesn't un-track files git already knows about).
data/*-bank-history.json

# Git backup directories left by `git` tooling (e.g. when running
# `git filter-repo` or moving a worktree). Three-day-old `.git.bak.*`
# directories are not source — just keep-it-in-case insurance.
dashboard/.git.bak.*/
